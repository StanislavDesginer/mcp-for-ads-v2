# For VPS/WPS beta use AD_MCP_ENV=production.
# Keep this file as placeholders only. Real secrets belong in server-side .env.
AD_MCP_ENV=development
AD_MCP_LOG_LEVEL=INFO
AD_MCP_AUDIT_LOG_PATH=logs/audit.jsonl
AD_MCP_CONNECTIONS_CONFIG=ads_config.yaml
AD_MCP_POLICY_CONFIG=config/policies/safety.example.yaml
AD_MCP_WEB_HOST=127.0.0.1
AD_MCP_WEB_PORT=8765
AD_MCP_WEB_API_TOKEN=change-this-beta-token
AD_MCP_WEB_MAX_BODY_BYTES=65536
AD_MCP_PREVIEW_ONLY=true
AD_MCP_PUBLIC_BASE_URL=https://mcp.adforge.example
AD_MCP_MCP_PUBLIC_URL=
AD_MCP_MCP_ENDPOINT_PATH=/mcp
AD_MCP_MCP_HTTP_HOST=127.0.0.1
AD_MCP_MCP_HTTP_PORT=8766
AD_MCP_META_OAUTH_REDIRECT_PATH=/oauth/meta/callback
AD_MCP_GOOGLE_OAUTH_REDIRECT_PATH=/oauth/google/callback
AD_MCP_TIKTOK_OAUTH_REDIRECT_PATH=/oauth/tiktok/callback
AD_MCP_YANDEX_OAUTH_REDIRECT_PATH=/oauth/yandex/callback
AD_MCP_META_OAUTH_APP_ID=your-meta-oauth-app-id
AD_MCP_META_OAUTH_APP_SECRET=your-meta-oauth-app-secret
AD_MCP_META_OAUTH_API_VERSION=v20.0
AD_MCP_META_OAUTH_SCOPES=ads_read,business_management
AD_MCP_META_OAUTH_STATE_TTL_SECONDS=900
AD_MCP_GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
AD_MCP_GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
AD_MCP_GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
AD_MCP_GOOGLE_ADS_LOGIN_CUSTOMER_ID=
AD_MCP_GOOGLE_ADS_API_VERSION=v20
AD_MCP_GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/adwords
AD_MCP_GOOGLE_OAUTH_STATE_TTL_SECONDS=900
AD_MCP_TIKTOK_OAUTH_APP_ID=your-tiktok-app-id
AD_MCP_TIKTOK_OAUTH_APP_SECRET=your-tiktok-app-secret
AD_MCP_TIKTOK_OAUTH_AUTH_URL=https://ads.tiktok.com/marketing_api/auth
AD_MCP_TIKTOK_OAUTH_TOKEN_URL=https://business-api.tiktok.com/open_api/v1.3/oauth2/access_token/
AD_MCP_TIKTOK_OAUTH_ADVERTISER_GET_URL=https://business-api.tiktok.com/open_api/v1.3/oauth2/advertiser/get/
AD_MCP_TIKTOK_OAUTH_SCOPES=
AD_MCP_TIKTOK_OAUTH_ADVERTISER_ID=
AD_MCP_TIKTOK_OAUTH_STATE_TTL_SECONDS=900
AD_MCP_YANDEX_OAUTH_CLIENT_ID=your-yandex-oauth-client-id
AD_MCP_YANDEX_OAUTH_CLIENT_SECRET=your-yandex-oauth-client-secret
AD_MCP_YANDEX_OAUTH_SCOPE=direct:api
AD_MCP_YANDEX_OAUTH_AUTHORIZE_URL=https://oauth.yandex.ru/authorize
AD_MCP_YANDEX_OAUTH_TOKEN_URL=https://oauth.yandex.ru/token
AD_MCP_YANDEX_DIRECT_CLIENTS_URL=https://api.direct.yandex.com/json/v5/clients
AD_MCP_YANDEX_DIRECT_LOGIN=your-agency-login
AD_MCP_YANDEX_DIRECT_CLIENT_LOGIN=your-client-login
AD_MCP_YANDEX_OAUTH_STATE_TTL_SECONDS=900
AD_MCP_CONNECTION_STORE_PATH=tokens/connections.json
AD_MCP_CONNECTIONS_FALLBACK_TO_LOCAL=false
META_APP_SECRET=your-meta-app-secret
META_ACCESS_TOKEN=your-meta-access-token
META_VARIKOZA_APP_SECRET=your-varikoza-app-secret
META_VARIKOZA_ACCESS_TOKEN=your-varikoza-access-token
META_INTERNA_APP_SECRET=your-interna-app-secret
META_INTERNA_ACCESS_TOKEN=your-interna-access-token
META_PALLADA_APP_SECRET=your-pallada-app-secret
META_PALLADA_ACCESS_TOKEN=your-pallada-access-token
